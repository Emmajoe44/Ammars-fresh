{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"const fs=require('fs');for(const f of['package-lock.json','yarn.lock'])fs.rmSync(f,{force:true});if(!/^pnpm\\//.test(process.env.npm_config_user_agent||'')){console.error('Use pnpm instead');process.exit(1)}\"",
    "dev": "pnpm --filter @workspace/ammars-fresh run dev",
    "dev:mobile": "powershell -ExecutionPolicy Bypass -File \"artifacts/AMMARS FRESH-mobile/scripts/dev-mobile.ps1\"",
    "build:mobile-apk": "powershell -ExecutionPolicy Bypass -File \"artifacts/AMMARS FRESH-mobile/scripts/build-apk.ps1\"",
    "apply:updates": "node scripts/apply-project-updates.mjs",
    "db:push": "node scripts/db-push.mjs",
    "db:seed": "node scripts/seed-demo.mjs",
    "db:up": "docker compose up -d",
    "db:check": "node scripts/ensure-db.mjs",
    "build": "pnpm run typecheck && pnpm -r --filter \"!./artifacts/AMMARS FRESH-mobile/**\" --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1",
    "tsx": "catalog:"
  }
}
