# Copy to .env and fill in values.
#   cp .env.example .env   (Unix)
#   copy .env.example .env (Windows)

# --- Database (required) ---
# Local (PostgreSQL on port 5432):
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agrimarket
#
# Production (Neon via Vercel — use the *pooled* connection string):
# DATABASE_URL=postgres://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# --- App URL (optional locally; auto-set from VERCEL_URL on Vercel) ---
# APP_URL=https://ammars-fresh.vercel.app

# --- Object storage: local dev (default) ---
# When PRIVATE_OBJECT_DIR is unset and not on Vercel, uploads go to .local-storage/

# --- Object storage: Vercel Blob (production on Vercel) ---
# Create in Vercel → Storage → Blob — adds BLOB_READ_WRITE_TOKEN automatically.

# --- Object storage: Google Cloud Storage (optional alternative) ---
# USE_LOCAL_OBJECT_STORAGE=false
# GCP_PROJECT_ID=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=./gcp/service-account.json
# PRIVATE_OBJECT_DIR=/your-gcs-bucket/private
# PUBLIC_OBJECT_SEARCH_PATHS=/your-gcs-bucket/public

# --- Demo data (optional) ---
# SEED_DEMO=true
