# Copy to .env and fill in values.
#   cp .env.example .env   (Unix)
#   copy .env.example .env (Windows)

# --- Database (required) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5433/agrimarket

# --- App URL (required in production for signed upload URLs & metadata) ---
# APP_URL=https://your-domain.com
# PORT=3000

# --- Object storage: local dev (default) ---
# When PRIVATE_OBJECT_DIR is unset, uploads go to .local-storage/ in this folder.
# No GCS account needed for local development.

# --- Object storage: Google Cloud Storage (production) ---
# Run from repo root:  pnpm --filter @workspace/agri-market run setup:gcs
# Or see scripts/setup-gcs.ps1 (requires Google Cloud SDK / gcloud).
#
# USE_LOCAL_OBJECT_STORAGE=false
# GCP_PROJECT_ID=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=./gcp/service-account.json
# PRIVATE_OBJECT_DIR=/your-gcs-bucket/private
# PUBLIC_OBJECT_SEARCH_PATHS=/your-gcs-bucket/public
